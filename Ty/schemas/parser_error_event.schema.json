{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Parser Error Event Schema",
  "description": "Schema for logging errors during the CPG extraction process.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    },
    "file_path": {
      "type": "string",
      "description": "File being parsed when error occurred"
    },
    "error_type": {
      "type": "string"
    },
    "error_message": {
      "type": "string"
    },
    "stack_trace": {
      "type": "string"
    }
  },
  "required": ["schema_version", "event_time", "file_path", "error_type", "error_message"]
}
